# The port number on which the local Express server will run
PORT=3000
# A secret key used for signing JWT tokens. Replace with a strong, unique value in production.
JWT_SECRET=your_secret_key
# Your MongoDB Atlas connection string. Replace credentials with your own connection details.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/personalVehicleManagement?retryWrites=true&w=majority
